# Spring profile
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Database
# Example for AWS RDS Postgres:
# jdbc:postgresql://your-db.xxxxx.us-east-1.rds.amazonaws.com:5432/closethop
DATASOURCE_URL=jdbc:postgresql://your-db-host:5432/closethop
DATASOURCE_USERNAME=your_db_username
DATASOURCE_PASSWORD=your_db_password

# Cognito
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/your_user_pool_id
COGNITO_CLIENT_ID=your_cognito_app_client_id

# AWS S3
AWS_S3_BUCKET=closethop-images
AWS_REGION=us-east-1
AWS_PUBLIC_URL=https://your-public-s3-or-cdn-url
PROCESSING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/closethop-image-processing
IMAGE_SIGNED_URL_MINUTES=15

# Frontend access
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# AI outfit suggestions
# Optional if you are not calling Gemini in prod.
GEMINI_API_KEY=your_gemini_api_key
OUTFIT_AI_MODEL=gemini-2.5-flash-lite
OUTFIT_SUGGESTION_PROMPT_PATH=classpath:prompts/outfit_suggestion_prompt.txt

# Optional runtime tuning
LOG_LEVEL=INFO
AI_RATE_LIMIT_PER_MINUTE=10
UPLOAD_RATE_LIMIT_PER_HOUR=30
PROCESSING_DEADLINE_SECONDS=15
PROCESSING_RECOVERY_INTERVAL_MS=2000
