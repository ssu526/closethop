AWS_REGION=us-east-1
AWS_S3_BUCKET=closethop-dev-images-123456789012-us-east-1
BACKUP_BUCKET=closethop-dev-postgres-backups-123456789012-us-east-1
BACKUP_PREFIX=postgres
PROCESSING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/closethop-dev-image-processing
PROCESSING_RESULT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/closethop-dev-image-processing-results
AWS_PUBLIC_URL=https://your-private-image-origin-or-cdn

POSTGRES_DB=closethop
POSTGRES_USER=closethop
POSTGRES_PASSWORD=change-me-use-a-long-random-value

COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_example
COGNITO_CLIENT_ID=exampleclientid
CORS_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app

GEMINI_API_KEY=your-gemini-api-key
OUTFIT_AI_MODEL=gemini-2.5-flash-lite
IMAGE_SIGNED_URL_MINUTES=15
